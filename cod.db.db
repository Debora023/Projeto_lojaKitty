 -- CLIENTES
 
SELECT email, numero
FROM Cliente
WHERE email = 'giovana@gmail.com';

SELECT email, numero
FROM Cliente
WHERE numero = '11981545512';

SELECT c.email, c.numero AS Cliente
FROM Cliente c;

SELECT nome, valor
FROM produtos
WHERE valor > 500.00;

SELECT localizacao, COUNT(*) AS total
FROM area_do_usuario
GROUP BY localizacao;

SELECT p.nome, c.nome AS categoria
FROM produtos p
JOIN categoria c ON p.categoria_id = c.id
WHERE c.nome IN ('Saia', 'vestidos', 'Acessórios', 'Calça', 'Calçados');

SELECT *
FROM pedidos
WHERE frete > 20;

SELECT Cliente.email, pedidos.subtotal, pedidos.frete
FROM pedidos
JOIN Cliente ON pedidos.cliente_id = Cliente.id;

SELECT pedidos.id, produtos.nome, itens_pedido.preco
FROM itens_pedido
JOIN produtos ON itens_pedido.produto_id = produtos.id
JOIN pedidos ON itens_pedido.pedido_id = pedidos.id;

SELECT *
FROM fornecedor;

SELECT id, nome_empresa, cnpj, cidade, estado
FROM fornecedor
ORDER BY nome_empresa;

SELECT *
FROM usuario_adm;

SELECT id, email, estoque_id, estoque_relatorio_id
FROM usuario_adm
ORDER BY id;


-- produtos
CREATE INDEX idx_produtos_nome ON produtos(nome);
CREATE INDEX idx_produtos_categoria_id ON produtos(categoria_id);

-- fornecedor
CREATE INDEX idx_fornecedor_cnpj ON fornecedor(cnpj);
CREATE INDEX idx_fornecedor_nome_empresa ON fornecedor(nome_empresa);

-- pedidos
CREATE INDEX idx_pedidos_cliente_id ON pedidos(cliente_id);
CREATE INDEX idx_pedidos_pagamento_id ON pedidos(pagamento_id);

-- itens_pedido
CREATE INDEX idx_itens_pedido_pedido_id ON itens_pedido(pedido_id);
CREATE INDEX idx_itens_pedido_produto_id ON itens_pedido(produto_id);

-- estoque
CREATE INDEX idx_estoque_usuario_adm_id ON estoque(usuario_adm_id);
CREATE INDEX idx_estoque_produto_id ON estoque(produto_id);
