SELECT c.email, c.numero AS Cliente
FROM Cliente c;












SELECT nome, valor
FROM produtos
WHERE valor > 100;


SELECT localizacao, COUNT(*) AS total
FROM area_do_usuario
GROUP BY localizacao;


SELECT p.nome, c.nome AS categoria
FROM produtos p
JOIN categoria c ON p.categoria_id = c.id
WHERE c.nome = 'Saia' OR c.nome = 'Vestido' OR c.nome = 'acessórios' or c.nome = 'Calças' OR c.nome = 'Calçados';


SELECT *
FROM pedidos
WHERE frete > 20;

SELECT Cliente.email, pedidos.subtotal, pedidos.frete
FROM pedidos
JOIN Cliente
ON pedidos.cliente_id = Cliente.id;

SELECT pedidos.id, produtos.nome, itens_pedido.preco
FROM itens_pedido
JOIN produtos ON itens_pedido.produto_id = produtos.id
JOIN pedidos ON itens_pedido.pedido_id = pedidos.id;
