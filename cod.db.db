SELECT *
FROM Cliente;


SELECT nome, valor
FROM produtos
WHERE valor > 100;


SELECT localizacao, COUNT(*) AS total
FROM area_do_usuario
GROUP BY localizacao;


SELECT nome, categoria
FROM produtos
WHERE categoria = 'Roupas';

SELECT *
FROM pedidos
WHERE frete > 20;

SELECT Cliente.email, pedidos.subtotal, pedidos.frete
FROM pedidos
JOIN Cliente
ON pedidos.cliente_id = Cliente.id;

SELECT pedidos.id, produtos.nome, itens_pedido.preco
FROM itens_pedido
JOIN produtos ON itens_pedido.produto_id = produtos.id
JOIN pedidos ON itens_pedido.pedido_id = pedidos.id;
